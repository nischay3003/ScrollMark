{
  "manifest_version": 3,
  "name": "ChatGPT Bookmark Tool",
  "version": "1.0",
  "description": "Bookmark scroll positions in ChatGPT",
  "permissions": ["storage", "activeTab", "scripting"],
  "content_scripts": [
    {
      "matches": ["https://chat.openai.com/*", "https://chatgpt.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}